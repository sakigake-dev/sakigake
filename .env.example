# ============================================================================
# Sakigake (魁) - Environment Variables Template
# ============================================================================
# Quick Start:
#   1. cp .env.example .env.local
#   2. 下記の値を埋める(各セクションの取得元リンク参照)
#   3. .env.local は git にコミットしないこと(.gitignore 済)
# ============================================================================

# ----------------------------------------------------------------------------
# Clerk - Authentication + Organizations
# 取得元: https://dashboard.clerk.com/
# ----------------------------------------------------------------------------
# API Keys (Dashboard > API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Webhook Signing Secret (Dashboard > Webhooks > 対象endpoint詳細)
# Endpoint URL: https://<your-domain>/api/webhooks/clerk
# 必要イベント: organization.* / organizationMembership.*
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# (任意) サインイン/サインアップページのパス
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ----------------------------------------------------------------------------
# Supabase - Postgres + RLS
# 取得元: https://supabase.com/dashboard > Project Settings > API
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service Role Key (server-side only, RLS bypass)
# ⚠️ クライアントに絶対公開しないこと
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ----------------------------------------------------------------------------
# Stripe - Subscription Billing
# 取得元: https://dashboard.stripe.com/
# ----------------------------------------------------------------------------
# API Keys (Developers > API keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook Secret (Developers > Webhooks > 対象endpoint詳細)
# Endpoint URL: https://<your-domain>/api/webhooks/stripe
# 必要イベント: customer.subscription.* / invoice.payment_*
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs (Dashboard > Products で作成した Price の ID)
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_PROFESSIONAL=price_...

# ----------------------------------------------------------------------------
# Inngest - Event-driven Background Jobs
# 取得元: https://app.inngest.com/ > Settings
# ----------------------------------------------------------------------------
# 開発時は `npx inngest-cli@latest dev` で Dev Server 起動、下記は空でOK
# 本番デプロイ時に必要
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Inngest Dev Server 接続フラグ(開発: true / 本番: false or 未設定)
INNGEST_DEV=true

# ----------------------------------------------------------------------------
# App Configuration
# ----------------------------------------------------------------------------
# 本番URL(Webhook の redirect_url や Clerk の after_sign_in 等で使用)
# 開発: http://localhost:3000 / 本番: https://sakigake.dev
NEXT_PUBLIC_APP_URL=http://localhost:3000
